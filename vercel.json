{
  "buildCommand": null,
  "outputDirectory": ".",
  "devCommand": null,
  "installCommand": null,
  "framework": null,
  "routes": [
    {
      "src": "/js/(.*)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/js/$1"
    },
    {
      "src": "/css/(.*)",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/css/$1"
    },
    {
      "src": "/icons/(.*)",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "dest": "/icons/$1"
    },
    {
      "src": "/sw.js",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/sw.js"
    },
    {
      "src": "/",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/index.html"
    },
    {
      "src": "/index.html",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/index.html"
    },
    {
      "src": "/manifest.json",
      "headers": {
        "cache-control": "no-cache, no-store, must-revalidate"
      },
      "dest": "/manifest.json"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
